generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id                 String         @id @default(uuid())
  nombre             String
  apellido           String
  email              String         @unique
  telefono           String?
  passwordHash       String?
  rol                Rol            @default(CLIENTE)
  activo             Boolean        @default(true)
  emailVerificado    Boolean        @default(false)
  tokenVerificacion  String?
  tokenVerificacionExpira DateTime?
  tokenReset         String?
  tokenResetExpira   DateTime?
  fotoPerfil         String?
  googleId           String?        @unique
  googleToken        String?
  empresaB2BId       String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  direcciones        Direccion[]
  empresaB2BPropia   EmpresaB2B?    @relation("EmpresaDueno")
  membresias         Membresia[]
  pedidosComoCliente Pedido[]       @relation("PedidoCliente")
  puntos             Puntos?
  refreshTokens      RefreshToken[]
  repartidor         Repartidor?
  empresaB2B         EmpresaB2B?    @relation("EmpresaEmpleados", fields: [empresaB2BId], references: [id])

  @@index([empresaB2BId], map: "usuarios_empresaB2BId_fkey")
  @@map("usuarios")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique @db.VarChar(500)
  usuarioId String
  expiresAt DateTime
  createdAt DateTime @default(now())
  usuario   Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId], map: "refresh_tokens_usuarioId_fkey")
  @@map("refresh_tokens")
}

model Direccion {
  id           String   @id @default(uuid())
  usuarioId    String
  calle        String
  numero       String
  colonia      String
  ciudad       String
  estado       String
  codigoPostal String
  referencia   String?
  esPrincipal  Boolean  @default(false)
  latitud      Float?
  longitud     Float?
  createdAt    DateTime @default(now())
  usuario      Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  pedidos      Pedido[]

  @@index([usuarioId], map: "direcciones_usuarioId_fkey")
  @@map("direcciones")
}

model Repartidor {
  id                   String           @id @default(uuid())
  usuarioId            String           @unique
  vehiculo             String?
  placas               String?
  licencia             String?
  estado               EstadoRepartidor @default(DISPONIBLE)
  latitudActual        Float?
  longitudActual       Float?
  calificacionPromedio Float            @default(0)
  totalServicios       Int              @default(0)
  fcmToken             String?          // Token FCM para notificaciones push
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  calificaciones       Calificacion[]
  pedidosEntrega       Pedido[]         @relation("PedidoRepartidorEntrega")
  pedidosRecoleccion   Pedido[]         @relation("PedidoRepartidorRecoleccion")
  usuario              Usuario          @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@map("repartidores")
}

model Pedido {
  id                      String            @id @default(uuid())
  clienteId               String
  direccionId             String?
  repartidorRecoleccionId String?
  repartidorEntregaId     String?
  estado                  EstadoPedido      @default(PENDIENTE)
  totalPrendas            Int
  tienePrendasExtra       Boolean           @default(false)
  fechaRecoleccion        DateTime?
  fechaEntregaEstimada    DateTime?
  fechaEntregaReal        DateTime?
  notasCliente            String?           @db.Text
  notasInternas           String?           @db.Text
  createdAt               DateTime          @default(now())
  updatedAt               DateTime          @updatedAt
  calificacion            Calificacion?
  historial               HistorialPedido[]
  pago                    Pago?
  cliente                 Usuario           @relation("PedidoCliente", fields: [clienteId], references: [id])
  direccion               Direccion?        @relation(fields: [direccionId], references: [id])
  repartidorEntrega       Repartidor?       @relation("PedidoRepartidorEntrega", fields: [repartidorEntregaId], references: [id])
  repartidorRecoleccion   Repartidor?       @relation("PedidoRepartidorRecoleccion", fields: [repartidorRecoleccionId], references: [id])
  prendas                 Prenda[]

  @@index([clienteId], map: "pedidos_clienteId_fkey")
  @@index([direccionId], map: "pedidos_direccionId_fkey")
  @@index([repartidorEntregaId], map: "pedidos_repartidorEntregaId_fkey")
  @@index([repartidorRecoleccionId], map: "pedidos_repartidorRecoleccionId_fkey")
  @@map("pedidos")
}

model HistorialPedido {
  id        String       @id @default(uuid())
  pedidoId  String
  estado    EstadoPedido
  nota      String?
  creadoPor String?
  createdAt DateTime     @default(now())
  pedido    Pedido       @relation(fields: [pedidoId], references: [id], onDelete: Cascade)

  @@index([pedidoId], map: "historial_pedidos_pedidoId_fkey")
  @@map("historial_pedidos")
}

model Prenda {
  id          String   @id @default(uuid())
  pedidoId    String
  tipo        String
  cantidad    Int      @default(1)
  descripcion String?
  precio      Float
  createdAt   DateTime @default(now())
  pedido      Pedido   @relation(fields: [pedidoId], references: [id], onDelete: Cascade)

  @@index([pedidoId], map: "prendas_pedidoId_fkey")
  @@map("prendas")
}

model CatalogoPrenda {
  id             String   @id @default(uuid())
  nombre         String   @unique
  descripcion    String?
  precioUnitario Float
  precioExtra    Float    @default(0)
  activo         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("catalogo_prendas")
}

model Pago {
  id              String     @id @default(uuid())
  pedidoId        String     @unique
  monto           Float
  metodoPago      MetodoPago
  estado          EstadoPago @default(PENDIENTE)
  puntosCanjeados Int        @default(0)
  paypalOrderId   String?
  paypalCaptureId String?
  recolectadoPor  String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  pedido          Pedido     @relation(fields: [pedidoId], references: [id])

  @@map("pagos")
}

model Puntos {
  id             String             @id @default(uuid())
  usuarioId      String             @unique
  saldo          Int                @default(0)
  totalGanados   Int                @default(0)
  totalCanjeados Int                @default(0)
  updatedAt      DateTime           @updatedAt
  movimientos    MovimientoPuntos[]
  usuario        Usuario            @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@map("puntos")
}

model MovimientoPuntos {
  id        String   @id @default(uuid())
  puntosId  String
  cantidad  Int
  concepto  String
  pedidoId  String?
  createdAt DateTime @default(now())
  puntos    Puntos   @relation(fields: [puntosId], references: [id], onDelete: Cascade)

  @@index([puntosId], map: "movimientos_puntos_puntosId_fkey")
  @@map("movimientos_puntos")
}

model Membresia {
  id            String          @id @default(uuid())
  usuarioId     String
  tipo          TipoMembresia   @default(BASICO)
  estado        EstadoMembresia @default(ACTIVA)
  fechaInicio   DateTime        @default(now())
  fechaFin      DateTime
  precio        Float
  descuento     Float           @default(0)
  pedidosGratis Int             @default(0)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  usuario       Usuario         @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  pagoMembresia PagoMembresia?

  @@index([usuarioId], map: "membresias_usuarioId_fkey")
  @@map("membresias")
}

model PagoMembresia {
  id            String     @id @default(uuid())
  membresiaId   String     @unique
  monto         Float
  metodoPago    MetodoPago
  estado        EstadoPago @default(PENDIENTE)
  paypalOrderId String?
  createdAt     DateTime   @default(now())
  membresia     Membresia  @relation(fields: [membresiaId], references: [id])

  @@map("pagos_membresia")
}

model EmpresaB2B {
  id            String       @id @default(uuid())
  nombre        String
  rfc           String?      @unique
  email         String       @unique
  telefono      String?
  direccion     String?
  duenoId       String       @unique
  activa        Boolean      @default(true)
  descuentoFijo Float        @default(0)
  limiteCredito Float        @default(0)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  contrato      ContratoB2B?
  dueno         Usuario      @relation("EmpresaDueno", fields: [duenoId], references: [id])
  empleados     Usuario[]    @relation("EmpresaEmpleados")

  @@map("empresas_b2b")
}

model ContratoB2B {
  id               String     @id @default(uuid())
  empresaId        String     @unique
  fechaInicio      DateTime
  fechaFin         DateTime
  condiciones      String?    @db.Text
  pedidosMensuales Int        @default(0)
  activo           Boolean    @default(true)
  createdAt        DateTime   @default(now())
  empresa          EmpresaB2B @relation(fields: [empresaId], references: [id])

  @@map("contratos_b2b")
}

model Calificacion {
  id           String     @id @default(uuid())
  pedidoId     String     @unique
  repartidorId String
  estrellas    Int
  comentario   String?    @db.Text
  createdAt    DateTime   @default(now())
  pedido       Pedido     @relation(fields: [pedidoId], references: [id])
  repartidor   Repartidor @relation(fields: [repartidorId], references: [id])

  @@index([repartidorId], map: "calificaciones_repartidorId_fkey")
  @@map("calificaciones")
}

enum Rol {
  CLIENTE
  REPARTIDOR
  ADMIN
  EMPLEADO
}

enum EstadoPedido {
  PENDIENTE
  CONFIRMADO
  RECOLECTADO
  EN_PROCESO
  LISTO
  EN_CAMINO
  ENTREGADO
  CANCELADO
}

enum EstadoPago {
  PENDIENTE
  COMPLETADO
  FALLIDO
  REEMBOLSADO
}

enum MetodoPago {
  PAYPAL
  EFECTIVO
}

enum EstadoRepartidor {
  DISPONIBLE
  OCUPADO
  INACTIVO
}

enum TipoMembresia {
  BASICO
  PREMIUM
  EMPRESARIAL
}

enum EstadoMembresia {
  ACTIVA
  EXPIRADA
  CANCELADA
}
